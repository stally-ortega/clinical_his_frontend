# ─────────────────────────────────────────────────────────────────────────────
#  .gitignore – Clinical HIS Frontend (Angular)
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log
yarn-error.log

# ── Angular Cache ─────────────────────────────────────────────────────────────
.angular/

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
tmp/
out-tsc/
bazel-out/

# ── Testing & Coverage ────────────────────────────────────────────────────────
coverage/
__screenshots__/

# ── Archivos de variables de entorno locales  ────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/

# ── Visual Studio Code ────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# ── Sistema Operativo ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misceláneos ───────────────────────────────────────────────────────────────
.sass-cache/
/connect.lock
/libpeerconnection.log
testem.log
/typings
